environment = 'production'

[auth]
jwt_secret = 'change-me-in-production'
token_expiry = '24h'
# breakglass = true                     # create break-glass admin on startup, env: VIRE_AUTH_BREAKGLASS

[auth.oauth2]
issuer = ''                          # MCP OAuth 2.1 issuer URL (e.g. 'https://api.vire.au'), env: VIRE_OAUTH2_ISSUER
# code_expiry = '10m'               # authorization code lifetime
# access_token_expiry = '1h'        # JWT access token lifetime
# refresh_token_expiry = '720h'     # refresh token lifetime (30 days)

[auth.github]
client_id = ''
client_secret = ''

[auth.google]
client_id = ''
client_secret = ''

[clients]
[clients.eodhd]
api_key = ''
base_url = 'https://eodhd.com/api'
rate_limit = 10
timeout = '30s'

[clients.gemini]
api_key = ''
max_content_size = '34MB'
max_urls = 20
model = 'gemini-2.5-flash'

[clients.gemini.models]
filing_summary = 'gemini-2.0-flash'   # PDF filing summarization (high volume, structured extraction)
analysis       = 'gemini-2.5-flash'   # stock/portfolio analysis (complex reasoning)

[clients.navexa]
base_url = 'https://api.navexa.com.au'
rate_limit = 5
timeout = '30s'

[jobmanager]
enabled = true
max_concurrent = 5
max_retries = 3
purge_after = '24h'
watcher_interval = '1m'
watcher_startup_delay = '10s'  # delay before first scan (env: VIRE_WATCHER_STARTUP_DELAY)
heavy_job_limit = 1            # max concurrent PDF-heavy jobs (env: VIRE_JOBS_HEAVY_LIMIT)

[logging]
file_path = 'logs/vire.log'
format = 'json'
level = 'info'
max_backups = 3
max_size_mb = 100
outputs = ['console', 'file']

[server]
host = '0.0.0.0'
port = 8080

[storage]
address = 'ws://localhost:8000/rpc'
data_path = 'data/market'
database = 'vire'
namespace = 'vire'
password = 'root'
username = 'root'

[storage.blob]
# Default: filesystem (data/blobs). Set bucket to enable S3-compatible storage.
path = 'data/blobs'                        # filesystem path (local dev)
# S3-compatible settings (bucket enables S3 mode):
# bucket   = 'vire-filings'               # setting this switches from filesystem to S3
# prefix   = 'vire'
# region   = 'auto'                        # AWS region, or 'auto' for Tigris/MinIO
# endpoint = ''                            # custom endpoint (Tigris, MinIO, R2)
# Credentials: prefer AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars
# access_key = ''
# secret_key = ''
